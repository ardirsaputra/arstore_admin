# Database
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/arstore?sslmode=require

# JWT — gunakan string acak panjang minimal 32 karakter
JWT_SECRET=ganti-dengan-string-acak-yang-sangat-panjang

# Default admin (dipakai saat db:init)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GantiPasswordIni!

# Durasi trial (hari) — harus sama dengan trialDays di Flutter (license_model.dart)
TRIAL_DAYS=30

# API request signing — harus sama dengan dart-define di Flutter build
# --dart-define=API_APP_KEY=... --dart-define=API_APP_SECRET=...
API_APP_KEY=utilitasku-v1
API_APP_SECRET=utsk-arstore-2025
