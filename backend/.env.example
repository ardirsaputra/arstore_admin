# NeonDB connection string
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/arstore?sslmode=require

# JWT secret — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Default admin credentials (used by db:init — change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!

# Server port
PORT=3001

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5000,https://your-admin-domain.com

# Trial duration in days
TRIAL_DAYS=14
